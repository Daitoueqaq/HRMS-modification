import pandas as pd
from selenium import webdriver
from selenium.webdriver.chrome.service import Service
from webdriver_manager.chrome import ChromeDriverManager
import time

file_path = 'A:/files/RHA1paper/metage/mca_mtb.xlsx'  # Replace with your file path
data = pd.read_excel(file_path, engine='openpyxl')
columns_to_fill = ['Row', 'Target', 'Studies', 'Assemblies', 'Pfam matches', 'Kingdom', 'Known Structure', 'Identical Seqs', '# hits', '# significant hits', 'Bit Score', 'Hit Positions', 'Full length', 'E-value']
data[columns_to_fill] = data[columns_to_fill].ffill()
data['Studies'] = data.groupby('Row')['Studies'].transform(lambda x: ', '.join(x.dropna().unique()))
data['Assemblies'] = data.groupby('Row')['Assemblies'].transform(lambda x: ', '.join(x.dropna().unique()))
data['Pfam matches'] = data.groupby('Row')['Pfam matches'].transform(lambda x: ', '.join(x.dropna().unique()))
data = data.drop_duplicates(subset='Row')
data.reset_index(drop=True, inplace=True)
service = Service(ChromeDriverManager().install())
driver = webdriver.Chrome(service=service)

base_url = 'https://www.ebi.ac.uk/metagenomics/studies/'
study_numbers = []

for studies in data['Studies']:
    if pd.notna(studies):
        individual_studies = studies.split(', ')
        numbers = []
        for study in individual_studies:
            url = f"{base_url}{study.strip()}"
            driver.get(url)
            time.sleep(7)  # Time for potential redirects
            final_url = driver.current_url
            study_id = final_url.split('/')[-1].split('#')[0]
            numbers.append(study_id)
        study_numbers.append(', '.join(numbers))
    else:
        study_numbers.append(None)

driver.quit()

data['Study Number'] = study_numbers
data.to_excel('A:/files/RHA1paper/metage/processed_mca_mst.xlsx', index=False)

