import pandas as pd
file_path = 'A:/files/RHA1paper/metage/processed_mca_mst.xlsx'  # Replace with your file path
data = pd.read_excel(file_path, engine='openpyxl')
data['Studies'] = data['Studies'].astype(str)
data['Study Number'] = data['Study Number'].astype(str)
data['Studies'] = data['Studies'].str.split(', ')
data['Study Number'] = data['Study Number'].str.split(', ')
exploded_data = data.explode('Studies').explode('Study Number')
assert len(exploded_data['Studies']) == len(exploded_data['Study Number']), "Mismatch in exploded data lengths."
studies_count = exploded_data['Studies'].value_counts().reset_index()
studies_count.columns = ['Studies', 'Count']
study_number_count = exploded_data['Study Number'].value_counts().reset_index()
study_number_count.columns = ['Study Number', 'Count']
merged_counts = pd.merge(studies_count, study_number_count, left_index=True, right_index=True, how='outer')

output_file_path = 'A:/files/RHA1paper/metage/studies_and_study_number_count-2.xlsx'
merged_counts.to_excel(output_file_path, index=False)


