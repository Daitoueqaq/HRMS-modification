import requests
import pandas as pd
file_path = 'A:/files/RHA1paper/metage/processed_mca_mst.xlsx'
data = pd.read_excel(file_path)
study_numbers = data['Study Number'].dropna().unique()

base_url = 'https://www.ebi.ac.uk/metagenomics/api/v1/studies/'

study_details = []
for study in study_numbers:
    # Fetch general study details to get the biome ID
    study_response = requests.get(f"{base_url}{study}")
    if study_response.status_code == 200:
        study_data = study_response.json().get('data', {})
        biome_id = study_data['relationships']['biomes']['data'][0]['id'] if study_data['relationships']['biomes']['data'] else 'No biome data'
        
        # Fetch geocoordinates for the study
        geo_response = requests.get(f"{base_url}{study}/geocoordinates")
        if geo_response.status_code == 200:
            geo_data = geo_response.json().get('data', [])
            if geo_data:  # Check if there is geo data available
                for item in geo_data:
                    study_details.append({
                        'Study Number': study,
                        'Biome ID': biome_id,
                        'Longitude': item['attributes']['longitude'],
                        'Latitude': item['attributes']['latitude']
                    })
            else:
                study_details.append({
                    'Study Number': study,
                    'Biome ID': biome_id,
                    'Longitude': 'No data',
                    'Latitude': 'No data'
                })
        else:
            print(f"Geo data fetch failed for {study}. Status Code: {geo_response.status_code}")
    else:
        print(f"Study details fetch failed for {study}. Status Code: {study_response.status_code}")

details_df = pd.DataFrame(study_details)
output_file_path = 'A:/files/RHA1paper/metage/complete_study_details_Mca_H37Rv.xlsx'
details_df.to_excel(output_file_path, index=False)
