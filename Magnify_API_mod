import pandas as pd
import requests

file_path = 'A:/files/RHA1paper/metage/wwtp_ori.xlsx'
data = pd.read_excel(file_path)
data['Sample'] = data['Sample'].apply(lambda x: ', '.join(set(x.split())) if pd.notnull(x) else x)
data = data.drop_duplicates(subset=['Sample'])
data.reset_index(drop=True, inplace=True)

base_url = 'https://www.ebi.ac.uk/metagenomics/api/v1/samples/'

for index, row in data.iterrows():
    if pd.notna(row['Sample']):
        samples = row['Sample'].split(', ')
        for sample in samples:
            response = requests.get(f"{base_url}{sample.strip()}")
            if response.status_code == 200:
                sample_data = response.json().get('data', {}).get('attributes', {})
                # Add longitude and latitude directly to the dataframe
                data.loc[index, 'Longitude'] = sample_data.get('longitude')
                data.loc[index, 'Latitude'] = sample_data.get('latitude')
            else:
                print(f"Failed to fetch data for {sample}. Status Code: {response.status_code}")
                data.loc[index, 'Longitude'] = 'No data'
                data.loc[index, 'Latitude'] = 'No data'

output_file_path = 'A:/files/RHA1paper/metage/processed_wwtp_ori.xlsx'
data.to_excel(output_file_path, index=False)

