import pandas as pd
import requests
import time
from tqdm import tqdm  # Import tqdm for the progress bar

evalue_threshold = 1e-5

input_csv = 'A:/files/RHA1paper/metage/hmmsearch/hmmsearch_results.csv'
data = pd.read_csv(input_csv)

data['Sample_ID'] = ''
data['Study_ID'] = ''
data['Longitude'] = ''
data['Latitude'] = ''
data['Geographic_Location'] = ''

runs_base_url = 'https://www.ebi.ac.uk/metagenomics/api/v1/runs/'
samples_base_url = 'https://www.ebi.ac.uk/metagenomics/api/v1/samples/'

for index, row in tqdm(data.iterrows(), total=data.shape[0], desc='Get a cup of coffee'):
    run_id = row['Sample_Number']  # Assuming 'Sample_Number' column contains run identifiers
    run_url = f"{runs_base_url}{run_id}"
    try:
        run_response = requests.get(run_url)
        if run_response.status_code == 200:
            run_data = run_response.json().get('data', {})
            # Extract sample identifier
            sample_relationship = run_data.get('relationships', {}).get('sample', {}).get('data', {})
            sample_id = sample_relationship.get('id', '')
            data.at[index, 'Sample_ID'] = sample_id
            # Extract study identifier
            study_relationship = run_data.get('relationships', {}).get('study', {}).get('data', {})
            study_id = study_relationship.get('id', '')
            data.at[index, 'Study_ID'] = study_id

            sample_url = f"{samples_base_url}{sample_id}"
            sample_response = requests.get(sample_url)
            if sample_response.status_code == 200:
                sample_attributes = sample_response.json().get('data', {}).get('attributes', {})
                # Extract longitude, latitude, and geographic location
                longitude = sample_attributes.get('longitude', '')
                latitude = sample_attributes.get('latitude', '')
                geo_loc_name = sample_attributes.get('geo-loc-name', '')
                data.at[index, 'Longitude'] = longitude
                data.at[index, 'Latitude'] = latitude
                data.at[index, 'Geographic_Location'] = geo_loc_name
            else:
                print(f"\nFailed to fetch sample data for {sample_id}. Status Code: {sample_response.status_code}")
        else:
            print(f"\nFailed to fetch run data for {run_id}. Status Code: {run_response.status_code}")
    except Exception as e:
        print(f"\nAn error occurred while processing run {run_id}: {e}")
    time.sleep(0.1)  # Pause for 0.1 seconds between requests

output_csv = 'hmmsearch_results_with_location.csv'
data.to_csv(output_csv, index=False)
