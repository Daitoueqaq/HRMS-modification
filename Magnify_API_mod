import pandas as pd
from selenium import webdriver
from selenium.webdriver.chrome.service import Service
from webdriver_manager.chrome import ChromeDriverManager
import time

file_path = 'A:/files/RHA1paper/metage/mca_mtb.xlsx'
data = pd.read_excel(file_path, engine='openpyxl')
data['Studies'] = data['Studies'].apply(lambda x: ', '.join(set(x.split(', '))) if pd.notnull(x) else x)
data = data.drop_duplicates(subset=['Studies'])
