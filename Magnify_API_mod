import re
input_file = 'C:/Users/boyua/Downloads/seq_mod.fasta'
output_file = 'C:/Users/boyua/Downloads/output_seq_mod.fasta'

with open(input_file, 'r') as infile, open(output_file, 'w') as outfile:
    for line in infile:
        if line.startswith('>'):
            match = re.search(r'\[(.*?)\]', line)
            if match:
                organism = match.group(1)
                # Replace spaces with underscores in the organism name
                organism = organism.replace(' ', '_')
                # Write the formatted header line with '>' to the output file
                outfile.write(f'>{organism}\n')
            else:
                outfile.write(line)
        else:
            outfile.write(line)

